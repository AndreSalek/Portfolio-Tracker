@{
    ViewData["Title"] = "Track every coin, in one place";
}

<section class="pt-landing">
    <div class="pt-landing__hero">
        @* ----- Left column: copy + CTAs ----- *@
        <div>
            <span class="pt-landing__eyebrow">
                <svg width="10" height="10" viewBox="0 0 10 10" aria-hidden="true">
                    <circle cx="5" cy="5" r="3" fill="currentColor"/>
                </svg>
                Live portfolio sync
            </span>

            <h1 class="pt-landing__title">
                One dashboard for <span>every exchange</span> you trade on.
            </h1>

            <p class="pt-landing__lead">
                Portfolio Tracker connects your exchange API keys, aggregates balances and
                trade history, and shows your true performance over time &mdash; without
                handing custody to anyone.
            </p>

            <div class="pt-landing__cta">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a class="btn btn-primary btn-lg" asp-controller="Portfolio" asp-action="Index">
                        Go to dashboard
                    </a>
                }
                else
                {
                    <a class="btn btn-primary btn-lg" asp-controller="Account" asp-action="Registration">
                        Get started &mdash; it's free
                    </a>
                    <a class="btn btn-outline btn-lg" asp-controller="Account" asp-action="Login">
                        Sign in
                    </a>
                }
            </div>
        </div>

        @* ----- Right column: animated SVG graph ----- *@
        <div class="pt-landing__visual">
            <div class="pt-graph">
                <svg class="pt-graph__svg" viewBox="0 0 800 360"
                     xmlns="http://www.w3.org/2000/svg" role="img"
                     aria-label="Animated portfolio value chart">
                    <defs>
                        @* Stroke gradient (blue) *@
                        <linearGradient id="pt-graph-line" x1="0" y1="0" x2="1" y2="0">
                            <stop offset="0%"  stop-color="#7aa9ff"/>
                            <stop offset="60%" stop-color="#3b82f6"/>
                            <stop offset="100%" stop-color="#1d4ed8"/>
                        </linearGradient>
                        @* Area fill gradient (fades down) *@
                        <linearGradient id="pt-graph-area" x1="0" y1="0" x2="0" y2="1">
                            <stop offset="0%"  stop-color="#3b82f6" stop-opacity="0.55"/>
                            <stop offset="60%" stop-color="#1e3a8a" stop-opacity="0.15"/>
                            <stop offset="100%" stop-color="#05070d" stop-opacity="0"/>
                        </linearGradient>
                    </defs>

                    @* Grid lines *@
                    <g class="pt-graph__grid">
                        <line x1="40" y1="80"  x2="760" y2="80"/>
                        <line x1="40" y1="160" x2="760" y2="160"/>
                        <line x1="40" y1="240" x2="760" y2="240"/>
                        <line x1="40" y1="320" x2="760" y2="320"/>
                    </g>

                    @* Axis labels (months) *@
                    <g class="pt-graph__axis">
                        <text x="40"  y="345">Jan</text>
                        <text x="170" y="345">Mar</text>
                        <text x="300" y="345">May</text>
                        <text x="430" y="345">Jul</text>
                        <text x="560" y="345">Sep</text>
                        <text x="690" y="345">Nov</text>
                    </g>

                    @* Filled area under the line *@
                    <path class="pt-graph__area"
                          d="M40,240 L105,220 L170,250 L235,200 L300,215 L365,175 L430,195 L495,145 L560,165 L625,110 L690,130 L760,65 L760,320 L40,320 Z"/>

                    @* The line itself — draws via stroke-dashoffset animation *@
                    <path class="pt-graph__line"
                          d="M40,240 L105,220 L170,250 L235,200 L300,215 L365,175 L430,195 L495,145 L560,165 L625,110 L690,130 L760,65"/>

                    @* Data-point dots *@
                    <g>
                        <circle class="pt-graph__dot" cx="105" cy="220" r="3.5"/>
                        <circle class="pt-graph__dot" cx="235" cy="200" r="3.5"/>
                        <circle class="pt-graph__dot" cx="365" cy="175" r="3.5"/>
                        <circle class="pt-graph__dot" cx="495" cy="145" r="3.5"/>
                        <circle class="pt-graph__dot" cx="625" cy="110" r="3.5"/>
                    </g>

                    @* Final dot with pulsing ring *@
                    <g>
                        <circle class="pt-graph__pulse" cx="760" cy="65" r="8"/>
                        <circle class="pt-graph__dot"   cx="760" cy="65" r="5"/>
                    </g>
                </svg>

                @* Floating tooltip near final dot *@
                <div class="pt-graph__tooltip">
                    <span class="pt-graph__tooltip-label">Portfolio &middot; Dec</span>
                    <span class="pt-graph__tooltip-value">$42,318</span>
                </div>
            </div>
        </div>
    </div>

    @* ----- Feature row ----- *@
    <div class="pt-landing__features">
        <article class="pt-card">
            <div class="pt-card__header">
                <h3 class="pt-card__title">Multi-exchange</h3>
            </div>
            <p>Bring balances from Binance, Coinbase, Kraken and more into a single view.</p>
        </article>
        <article class="pt-card">
            <div class="pt-card__header">
                <h3 class="pt-card__title">Read-only keys</h3>
            </div>
            <p>API keys are encrypted at rest and only ever used to read your data &mdash; never to trade.</p>
        </article>
        <article class="pt-card">
            <div class="pt-card__header">
                <h3 class="pt-card__title">Performance over time</h3>
            </div>
            <p>See realized P&amp;L, allocation drift, and cost basis across every position you hold.</p>
        </article>
    </div>
</section>
