@using Microsoft.AspNetCore.Identity

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <form id="logoutForm" class="form-inline" asp-controller="Account" asp-action="Logout">
            <button id="logout" type="submit" class="nav-link btn btn-link border-0">Logout</button>
        </form>
    </li>
}
<div>
    <form id="account" asp-controller="Account" asp-action="CreateAdminUser">
        <button type="submit" class="w-100 btn btn-lg btn-primary">Create Admin User</button>
    </form>
    <form id="account" asp-controller="Account" asp-action="LoginAdminUser">
        <button type="submit" class="w-100 btn btn-lg btn-primary">Login Admin User</button>
    </form>

</div>